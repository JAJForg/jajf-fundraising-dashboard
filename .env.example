# --- Access passwords (shared per-group, simplest setup) ---
TEAM_PASSWORD=changeme-team
BOARD_PASSWORD=changeme-board

# Random long string used to sign the login cookie. Generate with:
# openssl rand -base64 32
SESSION_SECRET=changeme-generate-a-random-string

# --- Blackbaud SKY API credentials ---
# Get these by registering a free app at https://developer.blackbaud.com
BLACKBAUD_CLIENT_ID=
BLACKBAUD_CLIENT_SECRET=
BLACKBAUD_SUBSCRIPTION_KEY=
BLACKBAUD_REDIRECT_URI=https://your-deployed-url.vercel.app/api/blackbaud/callback

# Fill this in after clicking "Connect Blackbaud" on the /admin page —
# it's shown to you once at the end of that flow. See README for details.
BLACKBAUD_REFRESH_TOKEN=

# The annual fundraising goal used to calculate progress %
ANNUAL_GOAL=1000000
